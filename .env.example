# Supabase Configuration
SUPABASE_PROJECT_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Modal Configuration
MODAL_TOKEN_ID=xxxx
MODAL_TOKEN_SECRET=xxxx
MODAL_WORKSPACE=your-workspace
MODAL_PROXY_AUTH_ENABLED=true

# APIs Configuration
VECINITA_MODEL_API_URL=https://your-workspace--vecinita-model-api.modal.run
VECINITA_EMBEDDING_API_URL=https://your-workspace--vecinita-embedding-web-app.modal.run

# Crawl4AI Configuration
CRAWL4AI_TIMEOUT_SECONDS=60
CRAWL4AI_MAX_DEPTH=3

# Chunking Configuration
CHUNK_MIN_SIZE_TOKENS=256
CHUNK_MAX_SIZE_TOKENS=1024
CHUNK_OVERLAP_RATIO=0.2

# Logging
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=development
