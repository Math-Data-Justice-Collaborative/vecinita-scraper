# Scraper service — Supabase / Modal / upstream URLs (placeholders only).
# Canonical environment catalog: repo root .env.example

SUPABASE_PROJECT_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_WORKSPACE=your-workspace
MODAL_PROXY_AUTH_ENABLED=true

OLLAMA_BASE_URL=https://your-workspace--vecinita-model-api.modal.run
EMBEDDING_UPSTREAM_URL=https://your-workspace--vecinita-embedding-web-app.modal.run

CRAWL4AI_TIMEOUT_SECONDS=60
CRAWL4AI_MAX_DEPTH=3
CHUNK_MIN_SIZE_TOKENS=256
CHUNK_MAX_SIZE_TOKENS=1024
CHUNK_OVERLAP_RATIO=0.2
LOG_LEVEL=INFO
ENVIRONMENT=development
